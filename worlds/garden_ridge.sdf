<?xml version="1.0" ?>
<!--
  주말농장 지형 — tools/make_garden_world.py 가 생성함. 직접 고치지 말 것.

  두둑 2개 · 폭 90cm · 높이 25cm · 길이 4.0m
  고랑 폭 30cm · 두둑 간격(pitch) 120cm
  → 포탈 로봇 트랙 120cm (바퀴가 고랑 한가운데)
  → 필요 클리어런스 60cm = 두둑 25 + 상추 25 + 여유 10

  근거: 농촌진흥청 농사로 — 두둑 높이 20~30cm, 고랑 폭 30cm 내외, 평이랑 90~120cm
-->
<sdf version="1.9">
  <world name="garden">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin filename="ignition-gazebo-physics-system"
            name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-sensors-system"
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="ignition-gazebo-scene-broadcaster-system"
            name="ignition::gazebo::systems::SceneBroadcaster"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.4 0.5 -0.85</direction>
    </light>

    <!-- 고랑 바닥 = 기준면 z=0. 로봇 바퀴가 굴러가는 곳. -->
    <model name="furrow_floor">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>30 30</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>30 30</size></plane></geometry>
          <material>
            <ambient>0.28 0.20 0.13 1</ambient>
            <diffuse>0.45 0.33 0.21 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- 두둑 1 · 중심 y=-0.60m · 윗면 z=0.25m -->
    <model name="bed_1">
      <static>true</static>
      <pose>0 -0.600 0.125 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>4.00 0.90 0.25</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>4.00 0.90 0.25</size></box></geometry>
          <material>
            <ambient>0.32 0.23 0.15 1</ambient>
            <diffuse>0.52 0.38 0.25 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="crop_1_0_0">
      <static>true</static>
      <pose>-1.800 -0.900 0.350 0 0 0</pose>
      <link name="link"><visual name="visual">
        <geometry><sphere><radius>0.09</radius></sphere></geometry>
        <material><ambient>0.10 0.30 0.08 1</ambient>
                  <diffuse>0.25 0.68 0.20 1</diffuse></material>
      </visual></link>
    </model>
    <model name="crop_1_0_1">
      <static>true</static>
