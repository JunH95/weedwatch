    <!-- 포탈 로봇 마네킹. 진짜 로봇은 Stage 2(URDF)에서 만든다.
         지금 확인하려는 건 딱 하나: 바퀴가 고랑에 들어가고 몸체가 두둑 위를 지나가는가. -->
    <model name="portal_mockup">
      <static>true</static>
      <pose>0 -0.600 0 0 0 0</pose>
      <link name="link">
        <!-- 가로 빔 -->
        <visual name="beam">
          <pose>0 0 0.640 0 0 0</pose>
          <geometry><box><size>0.14 1.28 0.08</size></box></geometry>
          <material><ambient>0.05 0.25 0.30 1</ambient>
                    <diffuse>0.09 0.45 0.53 1</diffuse></material>
        </visual>
        <!-- left 다리 -->
        <visual name="leg_left">
          <pose>0 -0.600 0.355 0 0 0</pose>
          <geometry><box><size>0.10 0.06 0.490</size></box></geometry>
          <material><ambient>0.05 0.25 0.30 1</ambient>
                    <diffuse>0.09 0.45 0.53 1</diffuse></material>
        </visual>
        <visual name="wheel_left">
          <pose>0 -0.600 0.110 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.110</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.06 0.06 0.07 1</ambient>
                    <diffuse>0.13 0.13 0.15 1</diffuse></material>
        </visual>
        <!-- right 다리 -->
        <visual name="leg_right">
          <pose>0 0.600 0.355 0 0 0</pose>
          <geometry><box><size>0.10 0.06 0.490</size></box></geometry>
          <material><ambient>0.05 0.25 0.30 1</ambient>
                    <diffuse>0.09 0.45 0.53 1</diffuse></material>
        </visual>
        <visual name="wheel_right">
          <pose>0 0.600 0.110 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.110</radius><length>0.08</length></cylinder></geometry>
          <material><ambient>0.06 0.06 0.07 1</ambient>
                    <diffuse>0.13 0.13 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- 검증용 관찰 카메라. 로봇에 달린 카메라가 아니라, 사람(과 에이전트)이
         '이 기하학이 말이 되나'를 눈으로 보려고 두는 것이다. -->
    <model name="inspector">
      <static>true</static>
      <pose>-3.2 -2.6 1.9 0 0.42 0.68</pose>
      <link name="link">
        <sensor name="cam" type="camera">
          <topic>garden/inspect</topic>
          <update_rate>10</update_rate>
          <always_on>1</always_on>
          <camera>
            <horizontal_fov>1.047</horizontal_fov>
            <image><width>960</width><height>720</height><format>R8G8B8</format></image>
            <clip><near>0.05</near><far>60</far></clip>
            <save enabled="true"><path>artifacts/garden</path></save>
          </camera>
        </sensor>
      </link>
    </model>

  </world>
</sdf>
